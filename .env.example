# Google OAuth Configuration
# Get your credentials from: https://console.cloud.google.com

# Your Google OAuth 2.0 Client ID (from Google Cloud Console)
NEXT_PUBLIC_GOOGLE_CLIENT_ID=YOUR_GOOGLE_CLIENT_ID_HERE.apps.googleusercontent.com

# Optional: Your Google OAuth 2.0 Client Secret (for backend verification)
# GOOGLE_CLIENT_SECRET=YOUR_GOOGLE_CLIENT_SECRET_HERE

# Other environment variables
NEXT_PUBLIC_SITE_URL=http://localhost:3000
NEXT_PUBLIC_SITE_NAME=JSEdumart Bookstore